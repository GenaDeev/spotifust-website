---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import spotifustLogo from '../assets/spotifust.png';
---

<Layout title="404 — Page Not Found | Spotifust" description="The page you're looking for doesn't exist. Head back to the Spotifust homepage.">
  <main class="error-page">
    <div class="container error-container">
      <Image width="80" height="80" src={spotifustLogo} alt="Spotifust Logo" class="error-logo" loading="eager" />

      <span class="error-code glow-text">404</span>

      <h1>Track Not Found</h1>

      <p class="error-description">
        This page doesn't exist in our playlist.<br />
        It might have been skipped, removed, or never queued.
      </p>

      <div class="error-visualizer" aria-hidden="true">
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
        <span class="bar"></span>
      </div>

      <a href="/" class="button primary">Back to Homepage</a>
    </div>
  </main>
</Layout>

<style>
  .error-page {
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem 0;
  }

  .error-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0;
  }

  .error-logo {
    width: 80px;
    height: 80px;
    padding: 4px;
    border-radius: 20px;
    box-shadow: 0 0 35px var(--color-accent-glow), 2px 2px 10px var(--color-text-muted) inset;
    background-color: var(--color-surface);
    margin-bottom: 2.5rem;
    transition: transform 0.3s ease;
  }

  .error-logo:hover {
    transform: scale(1.08) rotate(-3deg);
  }

  .error-code {
    font-family: var(--font-serif);
    font-size: 10rem;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1;
    letter-spacing: -0.04em;
    margin-bottom: 0.5rem;
    user-select: none;
  }

  .error-page h1 {
    font-family: var(--font-serif);
    font-size: 2.2rem;
    color: var(--color-text);
    margin-bottom: 1rem;
    font-weight: 600;
  }

  .error-description {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    max-width: 440px;
    line-height: 1.7;
    margin-bottom: 2.5rem;
  }

  .error-visualizer {
    display: flex;
    align-items: flex-end;
    gap: 5px;
    height: 40px;
    margin-bottom: 2.5rem;
  }

  .bar {
    display: block;
    width: 6px;
    border-radius: 3px;
    background-color: var(--color-accent);
    opacity: 0.6;
    animation: eq 1.2s ease-in-out infinite alternate;
  }

  .bar:nth-child(1) { height: 12px; animation-delay: 0s; }
  .bar:nth-child(2) { height: 24px; animation-delay: 0.15s; }
  .bar:nth-child(3) { height: 18px; animation-delay: 0.3s; }
  .bar:nth-child(4) { height: 36px; animation-delay: 0.45s; }
  .bar:nth-child(5) { height: 18px; animation-delay: 0.3s; }
  .bar:nth-child(6) { height: 24px; animation-delay: 0.15s; }
  .bar:nth-child(7) { height: 12px; animation-delay: 0s; }

  @keyframes eq {
    0% { transform: scaleY(0.3); opacity: 0.3; }
    100% { transform: scaleY(1); opacity: 0.7; }
  }

  .error-page .button.primary {
    font-size: 1rem;
    padding: 0.9rem 2rem;
  }

  @media (max-width: 768px) {
    .error-code {
      font-size: 6rem;
    }
    .error-page h1 {
      font-size: 1.6rem;
    }
    .error-description {
      font-size: 1rem;
    }
  }
</style>
